{
  "name": "aigc-friendly-architecture-backend",
  "version": "1.6.0",
  "description": "A NestJS backend architecture optimized for AIGC/Copilot scenarios.",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "npm run build:api",
    "prebuild:api": "node scripts/clean-dist.js && npm run capability:docs:check",
    "build:api": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "npm run start:api",
    "start:api": "NODE_ENV=production nest start",
    "start:dev": "npm run dev:api",
    "dev": "npm run dev:api",
    "dev:api": "TZ=Asia/Shanghai NODE_ENV=development nest start --watch",
    "start:debug": "TZ=Asia/Shanghai NODE_ENV=development nest start --debug --watch",
    "start:prod": "NODE_ENV=production node dist/bootstraps/api/main",
    "lint:usecase-normalize-guard": "node scripts/check-usecase-normalize-guard.js",
    "lint": "npm run capability:docs:check && npm run lint:usecase-normalize-guard && eslint \"{src,apps,libs,test,scripts}/**/*.ts\" --cache --cache-location .eslintcache --fix",
    "typecheck": "tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.tools.json --noEmit",
    "test:unit": "TZ=Asia/Shanghai jest",
    "test:watch": "TZ=Asia/Shanghai jest --watch",
    "test:cov": "TZ=Asia/Shanghai jest --coverage",
    "test:debug": "TZ=Asia/Shanghai node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test": "clear && TZ=Asia/Shanghai NODE_ENV=e2e node ./test/run-e2e-group.js core",
    "test:e2e": "clear && TZ=Asia/Shanghai NODE_ENV=e2e node ./test/run-e2e-group.js core",
    "test:e2e:core": "clear && TZ=Asia/Shanghai NODE_ENV=e2e node ./test/run-e2e-group.js core",
    "test:e2e:worker": "clear && TZ=Asia/Shanghai NODE_ENV=e2e node ./test/run-e2e-group.js worker",
    "test:e2e:smoke": "clear && TZ=Asia/Shanghai NODE_ENV=e2e node ./test/run-e2e-group.js smoke",
    "test:e2e:all": "npm run test:e2e:core && npm run test:e2e:worker",
    "test:e2e:file": "clear && TZ=Asia/Shanghai NODE_ENV=e2e node ./test/run-e2e-group.js --file",
    "test:e2e:watch": "TZ=Asia/Shanghai NODE_ENV=e2e node ./test/run-e2e-group.js --file --watch",
    "test:e2e:debug": "TZ=Asia/Shanghai NODE_ENV=e2e node ./test/run-e2e-group.js --file --inspect-brk",
    "migration:drill:empty-db": "TZ=Asia/Shanghai NODE_ENV=e2e ts-node -r tsconfig-paths/register src/infrastructure/database/verify-empty-db-migrations.ts",
    "ci:baseline-drill": "npm run migration:drill:empty-db",
    "dev:worker": "TZ=Asia/Shanghai NODE_ENV=development ts-node -r tsconfig-paths/register src/bootstraps/worker/main.ts",
    "start:worker": "NODE_ENV=production node dist/bootstraps/worker/main",
    "capability:list": "TZ=Asia/Shanghai ts-node -r tsconfig-paths/register scripts/capability-list.ts list",
    "capability:docs": "TZ=Asia/Shanghai ts-node -r tsconfig-paths/register scripts/capability-list.ts docs",
    "capability:docs:check": "TZ=Asia/Shanghai ts-node -r tsconfig-paths/register scripts/capability-list.ts check"
  },
  "dependencies": {
    "@apollo/server": "^5.5.1",
    "@as-integrations/express5": "^1.1.2",
    "@nestjs/apollo": "^13.4.2",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.27",
    "@nestjs/graphql": "^13.4.2",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/typeorm": "^11.0.3",
    "axios": "^1.18.1",
    "bullmq": "^5.79.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.4.2",
    "graphql": "^16.14.2",
    "graphql-type-json": "^0.3.2",
    "graphql-ws": "^6.0.7",
    "ioredis": "^5.11.1",
    "mysql2": "^3.22.5",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^1.0.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.43",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^6.0.0",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "prettier": "^3.9.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.6.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "overrides": {
    "@nestjs/graphql": {
      "subscriptions-transport-ws": {
        "ws": "7.5.11"
      },
      "ws": "8.21.0"
    },
    "@nestjs/platform-express": {
      "multer": "2.2.0"
    }
  },
  "packageManager": "npm@11.18.0"
}
