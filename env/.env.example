# Environment template. Copy to env/.env.development, env/.env.e2e, or env/.env.production and fill real values.

# Runtime
# NODE_ENV controls runtime mode. production enables production env validation and prod defaults.
# APP_HOST/APP_PORT bind the API HTTP listener.
# APP_NAME is a deployment label required by production validation.
# DEBUG is reserved for tooling/framework output; backend log verbosity uses LOG_LEVEL.
NODE_ENV=
APP_NAME=
APP_HOST=
APP_PORT=
DEBUG=

# Logging
# LOG_LEVEL: debug | info | warn | error
# LOG_INCLUDE_REQUEST_META: production-only toggle for 4xx request metadata.
# Non-production always includes 4xx request metadata.
LOG_LEVEL=
LOG_INCLUDE_REQUEST_META=

# HTTP / CORS
# APP_CORS_ORIGINS is comma-separated. Empty means allow any origin when CORS is enabled.
# Production validation requires explicit origins when CORS is enabled.
APP_CORS_ENABLED=true
APP_CORS_ORIGINS=
APP_CORS_CREDENTIALS=true

# GraphQL
# GRAPHQL_SANDBOX_ENABLED exposes the browser GraphQL sandbox.
# GRAPHQL_INTROSPECTION_ENABLED allows schema introspection.
GRAPHQL_SANDBOX_ENABLED=false
GRAPHQL_INTROSPECTION_ENABLED=false

# Database
# Prefer SSH tunnel or private network access. API and Worker may share the same DB config.
# DB_TIMEZONE is passed to TypeORM MySQL timezone handling.
# DB_POOL_SIZE is the MySQL connectionLimit.
# DB_SYNCHRONIZE=true lets TypeORM auto-sync Entity schema; forbidden in production.
# DB_LOGGING=true logs SQL statements.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=
DB_PASS=
DB_NAME=
DB_TIMEZONE=+08:00
DB_POOL_SIZE=10
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Redis / BullMQ
# REDIS_DB is the Redis logical database index.
# REDIS_PASSWORD empty disables Redis AUTH.
# BULLMQ_PREFIX is the Redis key namespace for BullMQ queues/jobs.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=15
REDIS_PASSWORD=
REDIS_TLS=false
BULLMQ_PREFIX=bullmq

# Security
# FIELD_ENCRYPTION_* must be at least 16 characters.
# Keep FIELD_ENCRYPTION_* stable; changing them breaks existing encrypted field reads.
# JWT_*_EXPIRES_IN uses jsonwebtoken duration format, for example 1h or 7d.
# JWT_REFRESH_EXPIRES_IN is parsed config; current refresh tokens use JWT_EXPIRES_IN.
# JWT_ENABLE_REFRESH is parsed config; current login flow does not use it to gate refresh tokens.
# JWT_AUDIENCE is comma-separated and used for JWT verify/audience validation.
# PAGINATION_HMAC_SECRET signs cursor pagination tokens; changing it invalidates old cursors.
FIELD_ENCRYPTION_KEY=
FIELD_ENCRYPTION_IV=
JWT_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ALGORITHM=HS256
JWT_ENABLE_REFRESH=true
JWT_ISSUER=ssts-local
JWT_AUDIENCE=DESKTOP,SSTSTEST,SSTSWEB,SSTSWEAPP,SJWEB,SJWEAPP
PAGINATION_HMAC_SECRET=

# Worker entry guards
# Enables GraphQL queue enqueue/debug entrypoints; does not start/stop workers.
# AI queue entries also require STAFF/ADMIN. Email queue entry only checks this flag.
AI_QUEUE_DEBUG_ENABLED=false
EMAIL_QUEUE_DEBUG_ENABLED=false

# Capability runtime
# Loaded at process start. Restart API/Worker after file changes.
# CAPABILITY_DISABLED_IDS: comma-separated switchable capability ids configured as disabled.
CAPABILITY_DISABLED_IDS=

# Email delivery
# EMAIL_SEND_AS_USER runs sendmail through sudo -n -u <user> when non-empty.
# EMAIL_SENDMAIL_PATH is the sendmail binary path used by the worker.
EMAIL_SEND_AS_USER=no-reply-ssts
EMAIL_SENDMAIL_PATH=/usr/sbin/sendmail

# AI provider routing
# mock: force local mock provider.
# remote: use real provider only when the request explicitly selects one; otherwise keep local mock.
AI_PROVIDER_MODE=mock

# Qwen provider
# QWEN_GENERATE_MODEL is used by real AI E2E smoke requests, not as a backend default model.
# QWEN_AUTH_FAIL_API_KEY is used only by RUN_REAL_AI_AUTH_FAIL_E2E.
QWEN_BASE_URL=
QWEN_API_KEY=
QWEN_GENERATE_MODEL=
QWEN_GENERATE_TIMEOUT_MS=30000
QWEN_AUTH_FAIL_API_KEY=

# OpenAI provider
# Model is supplied by request payload; this config only defines the remote endpoint/client.
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_GENERATE_TIMEOUT_MS=30000

# Third-party auth / WeApp
# Used by WeApp third-party auth provider for code/session/phone/qrcode calls.
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# E2E runner
# E2E_GROUP: core | worker | smoke. Empty defaults to core.
# E2E_SPECS: comma-separated *.e2e-spec.ts files; overrides selected group specs.
# E2E_NEEDS: comma-separated mysql,redis,bullmq,external; empty derives from group.
# E2E_SKIP_INFRA_CHECKS skips setup checks for declared needs.
# E2E_SKIP_DB_CLEANUP skips test DB cleanup in global setup.
# RUN_REAL_AI_E2E enables real Qwen smoke and requires AI_PROVIDER_MODE=remote plus QWEN_*.
# RUN_REAL_AI_AUTH_FAIL_E2E enables real auth-failure smoke and requires QWEN_AUTH_FAIL_API_KEY.
# E2E_EMAIL_TO is the recipient for real email delivery smoke.
# WEAPP_QRCODE_SMOKE_AUDIENCE selects the WeApp qrcode smoke audience.
E2E_GROUP=
E2E_SPECS=
E2E_NEEDS=
E2E_SKIP_INFRA_CHECKS=false
E2E_SKIP_DB_CLEANUP=false
RUN_REAL_AI_E2E=false
RUN_REAL_AI_AUTH_FAIL_E2E=false
E2E_EMAIL_TO=
WEAPP_QRCODE_SMOKE_AUDIENCE=SSTSWEAPP

# Migration drill
# Read by npm run migration:drill:empty-db.
# MIGRATION_DRILL_DOTENV overrides the dotenv file loaded by the drill script.
# MIGRATION_DRILL_DATABASE overrides DB_NAME as the target empty database.
# MIGRATION_DRILL_CREATE_TEMP_DB=true creates and drops a temporary drill database.
# MIGRATION_DRILL_ALLOW_NON_TEST_DB=true allows target DB names without test/drill/ci.
MIGRATION_DRILL_DOTENV=
MIGRATION_DRILL_DATABASE=
MIGRATION_DRILL_CREATE_TEMP_DB=false
MIGRATION_DRILL_ALLOW_NON_TEST_DB=false
