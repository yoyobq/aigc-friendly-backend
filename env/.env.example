# Environment template. Copy to env/.env.development, env/.env.e2e, or env/.env.production and fill real values.

# Runtime
NODE_ENV=
APP_NAME=
APP_HOST=
APP_PORT=
DEBUG=

# Logging
# LOG_LEVEL: debug | info | warn | error
# LOG_INCLUDE_REQUEST_META: include request metadata for 4xx responses (true/false)
LOG_LEVEL=
LOG_INCLUDE_REQUEST_META=

# HTTP / CORS
# APP_CORS_ORIGINS is comma-separated. Production requires explicit origins when CORS is enabled.
APP_CORS_ENABLED=true
APP_CORS_ORIGINS=
APP_CORS_CREDENTIALS=true

# GraphQL
GRAPHQL_SANDBOX_ENABLED=false
GRAPHQL_INTROSPECTION_ENABLED=false

# Database
# Prefer SSH tunnel or private network access. API and Worker may share the same DB config.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=
DB_PASS=
DB_NAME=
DB_TIMEZONE=+08:00
DB_POOL_SIZE=10
DB_SYNCHRONIZE=false
DB_LOGGING=false

# Redis / BullMQ
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=15
REDIS_PASSWORD=
REDIS_TLS=false
BULLMQ_PREFIX=bullmq

# Security
# FIELD_ENCRYPTION_* must be at least 16 characters.
FIELD_ENCRYPTION_KEY=
FIELD_ENCRYPTION_IV=
JWT_SECRET=
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d
JWT_ALGORITHM=HS256
JWT_ENABLE_REFRESH=true
JWT_ISSUER=ssts-local
JWT_AUDIENCE=DESKTOP,SSTSTEST,SSTSWEB,SSTSWEAPP,SJWEB,SJWEAPP
PAGINATION_HMAC_SECRET=

# Worker entry guards
# Enable only when the corresponding GraphQL queue entry should be available.
AI_QUEUE_DEBUG_ENABLED=false
EMAIL_QUEUE_DEBUG_ENABLED=false

# Capability runtime
# CAPABILITY_DISABLED_IDS: comma-separated capability ids.
# CAPABILITY_KILL_SWITCH_IDS: comma-separated capability ids.
# CAPABILITY_OPERATION_DISABLED_KEYS format: capabilityId:operationKind:operation
# CAPABILITY_PERMISSION_GRANTS format: permission=ROLE|ROLE;other.permission=ROLE
CAPABILITY_DISABLED_IDS=
CAPABILITY_KILL_SWITCH_IDS=
CAPABILITY_OPERATION_DISABLED_KEYS=
CAPABILITY_PERMISSION_GRANTS=

# Email delivery
EMAIL_SEND_AS_USER=no-reply-ssts
EMAIL_SENDMAIL_PATH=/usr/sbin/sendmail

# AI provider routing
# mock: force local mock provider.
# remote: use real provider only when the request explicitly selects one; otherwise keep local mock.
AI_PROVIDER_MODE=mock

# Qwen provider
QWEN_BASE_URL=
QWEN_API_KEY=
QWEN_GENERATE_MODEL=
QWEN_GENERATE_TIMEOUT_MS=30000
QWEN_AUTH_FAIL_API_KEY=

# OpenAI provider
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_GENERATE_TIMEOUT_MS=30000

# Third-party auth / WeApp
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# E2E runner
# Leave empty for default group/suite selection.
E2E_GROUP=
E2E_SPECS=
E2E_NEEDS=
E2E_SKIP_INFRA_CHECKS=false
E2E_SKIP_DB_CLEANUP=false
RUN_REAL_AI_E2E=false
RUN_REAL_AI_AUTH_FAIL_E2E=false
E2E_EMAIL_TO=
WEAPP_QRCODE_SMOKE_AUDIENCE=SSTSWEAPP

# Migration drill
# These are read by npm run migration:drill:empty-db.
MIGRATION_DRILL_DOTENV=
MIGRATION_DRILL_DATABASE=
MIGRATION_DRILL_CREATE_TEMP_DB=false
MIGRATION_DRILL_ALLOW_NON_TEST_DB=false
